# Copy this file to .env and fill in real values for local development.
# On Replit these come from Secrets and this file is ignored.

# --- Required ---
# Postgres connection string (any standard Postgres: local, Neon, Supabase, Replit).
# Local example:  postgres://postgres:postgres@localhost:5432/littr
# Neon example:   postgres://USER:PASSWORD@ep-xxxx.us-east-2.aws.neon.tech/littr?sslmode=require
DATABASE_URL=

# Port the server listens on (defaults to 5000 if unset)
PORT=5000

# --- Optional (features degrade gracefully if unset) ---
# Resend API key for outbound email (contact/lead/volunteer notifications, partner
# invites, alert notifications). Without it, email sends are skipped/logged.
RESEND_API_KEY=

# Google reCAPTCHA secret (customer registration). Without it, captcha checks are lenient.
RECAPTCHA_SECRET_KEY=

# Public base URL used to build claim/invite links (e.g. https://littr.co).
# Defaults to the request origin if unset.
# BASE_URL=http://localhost:5000

# Where device photos and firmware/content artifacts are stored.
#   unset | local  -> local disk under ./uploads, served at /uploads (default)
#   s3             -> declared but NOT implemented; boot fails with a pointer to
#                     the TODO(s3) contract in server/blobstore/driver.ts
# Local disk is per-instance: on autoscaled/ephemeral hosting the objects 404
# from sibling instances and vanish on redeploy, which breaks review-queue
# photos and the OTA/content-pack downloads bins depend on. Single-instance
# deploys (today) are fine — leave this unset.
# STORAGE_DRIVER=local
